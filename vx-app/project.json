{
  "name": "vx-app",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "vx-app",
  "projectType": "application",
  "tags": ["frontend", "nextjs"],
  "// targets": "to see all targets run: nx show project vx-app --web",
  "targets": {
    "vx-app": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "dev": true,
        "port": 3001
      },
      "configurations": {
        "development": {
          "buildTarget": "varius.dev:build:development"
        },
        "production": {
          "buildTarget": "varius.dev:build:production"
        }
      }
    }
  }
}
